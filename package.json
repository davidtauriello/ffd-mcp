{
  "name": "filing-fee-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for SEC EDGAR Exhibit 107 filing fee disclosure analysis. Parses ffd: XBRL from registration statements.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "filing-fee-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "Dockerfile",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sec",
    "edgar",
    "filing-fees",
    "exhibit-107",
    "xbrl",
    "ffd"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidtauriello/ffd-mcp.git"
  },
  "author": "David Tauriello",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0 || ^6.0.0"
  }
}
