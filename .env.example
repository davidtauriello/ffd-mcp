# ── SEC EDGAR (required) ──────────────────────────────────────────────
# User-Agent header for SEC compliance. The SEC blocks requests without one.
# Format: "AppName contact@email.com"
EDGAR_USER_AGENT=

# ── Transport ─────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio (default) | http
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)

# ── SEC rate limit ────────────────────────────────────────────────────
# EDGAR_RATE_LIMIT_RPS=10           # Max requests/second (max 10, default 10)
# EDGAR_TICKER_CACHE_TTL=3600       # Seconds to cache company_tickers.json
